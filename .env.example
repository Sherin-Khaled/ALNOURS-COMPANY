# Local development: copy this file to `.env` and replace placeholder values.
# Production on Hostinger: configure these values in Hostinger environment settings.

DATABASE_URL=postgresql://username:password@host:5432/database
NODE_ENV=development
PORT=5000
# Required in production. Use your final public HTTPS origin with no path, query, or trailing slash.
APP_BASE_URL=http://127.0.0.1:5000
SESSION_SECRET=replace_with_a_long_random_secret
# Hostinger Business should keep this at 1 behind the reverse proxy.
TRUST_PROXY=1
# Optional. Leave blank for host-only cookies, or set your production cookie domain like `.example.com`.
COOKIE_DOMAIN=

ODOO_BASE_URL=https://your-odoo-instance.example.com
ODOO_DB=your_odoo_database
ODOO_USERNAME=your_odoo_service_account@example.com
ODOO_API_KEY=your_odoo_api_key
ODOO_LANG_EN=en_US
ODOO_LANG_AR=ar_001

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=mailer@example.com
SMTP_PASS=your_smtp_password
SMTP_FROM=mailer@example.com

# Set to `test` until you are ready to go live with Moyasar production keys.
MOYASAR_MODE=test
MOYASAR_PUBLISHABLE_KEY=pk_test_your_publishable_key
MOYASAR_SECRET_KEY=sk_test_your_secret_key
MOYASAR_WEBHOOK_SECRET=your_moyasar_webhook_secret
